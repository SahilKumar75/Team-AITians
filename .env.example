# Copy to .env.local (or .env.production for build) and fill in values.
# See docs/DEPLOYMENT.md for full reference.

# --- Static build + IPFS (Pinata) ---
NEXT_PUBLIC_USE_CLIENT_DATA=true
NEXT_PUBLIC_POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
NEXT_PUBLIC_POLYGON_CHAIN_ID=80002
NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_HEALTH_REGISTRY_ADDRESS=0x...

# --- Pinata upload script (optional): get JWT from https://app.pinata.cloud → API Keys
# PINATA_JWT=your_jwt

# --- Production (if using server/NextAuth)
# NEXTAUTH_URL=https://your-production-domain.com
# NEXTAUTH_SECRET=<strong-random-secret>
# POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# --- Contract deploy (never commit real key)
# DEPLOYER_PRIVATE_KEY=0x...

# --- Optional: SMS (e.g. Fast2SMS)
# FAST2SMS_API_KEY=<your-key>
